{
  "name": "yesterlog",
  "version": "3.0.0",
  "private": true,
  "description": "Yesterlog is local-first Jira time tracking with optional Ollama, Anthropic, or OpenAI assistance.",
  "license": "MIT",
  "author": "fourgray <fourgray@proton.me>",
  "repository": {
    "type": "git",
    "url": "https://github.com/4gray/yesterlog.git"
  },
  "homepage": "https://4gray.github.io/yesterlog/",
  "bugs": {
    "url": "https://github.com/4gray/yesterlog/issues"
  },
  "desktopName": "yesterlog.desktop",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON_TS,ELECTRON -c green,blue,magenta \"vite --host 127.0.0.1\" \"tsc -p tsconfig.electron.json --watch --preserveWatchOutput\" \"wait-on tcp:5173 dist-electron/electron/main.js && VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron dist-electron/electron/main.js\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "assets:icons": "node scripts/generate-icons.mjs",
    "media:banners": "node scripts/generate-marketing-banners.mjs",
    "build": "tsc --noEmit && vite build && tsc -p tsconfig.electron.json",
    "dist": "npm run build && electron-builder",
    "dist:all": "npm run build && electron-builder --mac dmg zip --win nsis zip --linux AppImage deb tar.gz --publish never",
    "dist:mac": "npm run build && electron-builder --mac dmg zip --publish never",
    "dist:win": "npm run build && electron-builder --win nsis zip --publish never",
    "dist:linux": "npm run build && electron-builder --linux AppImage deb tar.gz --publish never",
    "dist:snap": "npm run build && electron-builder --linux snap --publish never",
    "dist:snap:stage": "npm run build && node scripts/stage-snap.mjs",
    "check:brand": "node scripts/check-brand.mjs",
    "release:dry-run": "npm run check:brand && npm run test && npm run e2e:renderer && npm run build",
    "release:patch": "npm version patch -m \"chore(release): v%s\"",
    "release:minor": "npm version minor -m \"chore(release): v%s\"",
    "release:major": "npm version major -m \"chore(release): v%s\"",
    "release:push": "git push && git push --tags",
    "lint": "tsc --noEmit",
    "preview": "vite preview --host 127.0.0.1",
    "screenshots": "node scripts/capture-screenshots.mjs",
    "screenshots:install-browser": "playwright install chromium",
    "screenshots:release": "node scripts/capture-screenshots.mjs --seed release --today 2026-06-17",
    "test": "vitest run",
    "e2e:renderer": "node --test e2e/renderer.e2e.mjs"
  },
  "dependencies": {
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^8.2.2",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.1",
    "typescript": "^5.5.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "io.github.fourgray.yesterlog",
    "productName": "Yesterlog",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "4gray",
        "repo": "yesterlog",
        "releaseType": "release"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": true
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "guid": "29d07a6a-c22b-5254-9ae6-80b17064706b"
    },
    "linux": {
      "icon": "build/icons/512x512.png",
      "category": "Office",
      "synopsis": "Local weekly Jira time tracking",
      "description": "Yesterlog is a local-first desktop companion for weekly Jira time tracking. Sync and review Jira worklogs, reconstruct forgotten days without AI, or optionally polish drafts with local Ollama, Anthropic via the Claude CLI, or OpenAI via the Codex CLI. Cloud AI is opt-in and uses your existing CLI authentication. There is no Yesterlog backend or telemetry.",
      "syncDesktopName": true,
      "target": [
        "AppImage",
        "deb",
        "tar.gz"
      ]
    },
    "deb": {
      "fpm": [
        "--replaces=timebro",
        "--conflicts=timebro"
      ]
    },
    "snapcraft": {
      "base": "core24",
      "core24": {
        "title": "Yesterlog",
        "summary": "Local weekly Jira time tracking for your desktop",
        "confinement": "strict",
        "grade": "stable",
        "extensions": [
          "gnome"
        ],
        "plugs": [
          "network",
          "home",
          "browser-support"
        ],
        "executableArgs": [
          "--no-sandbox"
        ]
      }
    }
  }
}
